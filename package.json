{
  "name": "external-data-api",
  "version": "1.0.0",
  "description": "Minimal REST API in Node.js + Express + TypeScript consuming Frankfurter API",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
